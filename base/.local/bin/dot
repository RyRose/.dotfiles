#!/usr/bin/env -S uv run --script
# /// script
# dependencies = [
#     "typer",
# ]
# ///

import os
import platform
import shutil
import subprocess
from pathlib import Path
from typing import Annotated

import typer

app = typer.Typer(help="Manage dotfiles.", no_args_is_help=True)

nix = typer.Typer(help="Nix related commands.", no_args_is_help=True)
app.add_typer(nix, name="nix")


def nix_rebuild():
    match platform.system():
        case "Linux":
            return "nixos-rebuild"
        case "Darwin":
            return "darwin-rebuild"
        case _:
            raise NotImplementedError("Unsupported platform.")


@nix.command(help="Reload NixOS configuration.")
def reload(target: str):
    os.chdir(Path.home() / ".dotfiles")
    subprocess.run(["sudo", nix_rebuild(), "switch", "--flake", f"./nixos#{target}"])


@nix.command(
    help="Update NixOS flake. Run `dot nix update` to update the flake and then `dot nix reload` to apply the changes."
)
def update():
    os.chdir(Path.home() / ".dotfiles/nixos")
    subprocess.run(["nix", "flake", "update"])


@nix.command(help="Rollback NixOS system.")
def rollback(target: str):
    os.chdir(Path.home() / ".dotfiles")
    subprocess.run(
        ["sudo", nix_rebuild(), "switch", "--rollback", "--flake", f"./nixos#{target}"]
    )


@app.command(help="Run make in the dotfiles directory on a target.")
def make(target: Annotated[str, typer.Argument()] = ""):
    assert shutil.which("make"), "Make is not installed."
    assert shutil.which("stow"), "Stow is not installed."

    os.chdir(Path.home() / ".dotfiles")
    subprocess.run(["make", target])


@app.command(help="Edit dotfiles in Neovim.")
def edit():
    os.chdir(Path.home() / ".dotfiles")
    subprocess.run(["nvim"])


@app.command(help="Initialize dotfiles management.")
def git(args: list[str]):
    os.chdir(Path.home() / ".dotfiles")
    subprocess.run(["git"] + args)


if __name__ == "__main__":
    app()
